{
  "compilerOptions": {
    "target": "ES2019",
    "module": "commonjs",
    "outDir": "./out",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2019", "dom"], // ← 添加这一行
    "removeComments": true,
    "stripInternal": true,
    "types": ["node"]
  }
}